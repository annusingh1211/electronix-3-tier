pipeline{
    agent {
        label 'electronix'
    }

    stages{
        stage('Creating Database'){
            steps{
                sh 'python3 scripts/create_db.py'
            }
        }
    }

    post{
        success{
            echo 'Databse Creation Successfully‚úÖ'
        }

        failure{
            echo 'Database Failed‚ùå'
        }
    }
}